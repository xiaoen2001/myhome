# === Root .gitignore for note-share-platform ===

# ---- Sensitive Config (DO NOT COMMIT) ----
application.yml
src/main/resources/application.yml
**/application-*.yml
!**/application-example.yml

# ---- Credentials & Secrets ----
*.pem
*.key
*.p12
*.jks
*.keystore
*.pwd
.env
.env.*
!**/.env.example

# ---- IDE ----
.idea/
.vscode/
*.iml
*.iws
*.ipr

# ---- Java / Maven ----
target/
!.mvn/wrapper/maven-wrapper.jar
*.class
*.jar
!gradle/wrapper/gradle-wrapper.jar

# ---- Node / Frontend ----
node_modules/
dist/
dist-ssr/
*.local

# ---- OS ----
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---- Uploaded Content (user-generated images) ----
**/uploads/
**/carousels/
**/photos/

# ---- SQL Dumps (may contain real data) ----
*.sql

# ---- Personal Documents ----
*.pdf
*.doc
*.docx
*.pptx

# ---- Logs ----
logs/
*.log
